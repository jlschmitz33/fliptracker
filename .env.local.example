# Turso (SQLite cloud database) — https://turso.tech
# Get these from: turso db show --url <db-name> and turso db tokens create <db-name>
TURSO_DATABASE_URL=libsql://your-db-name-yourname.turso.io
TURSO_AUTH_TOKEN=your-token-here

# Vercel Blob (photo storage) — auto-set when you add Blob Storage in Vercel dashboard
# For local dev, get a token from your Vercel project settings > Storage > Blob
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
